/** @var Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */
/** @var Wallee\Payment\ViewModel\WhitelabelMachineNameCheckoutViewModel $viewModel */

$viewModel = $block->getViewModel();
$method = $block->getMethod();
if (!$method) {
    return;
}
$methodCode = $method->getCode();

// Only proceed if it's one of our payment methods.
if (strpos($methodCode, 'wallee_payment_') !== 0) {
    return;
}

$configData = $viewModel->getPaymentIntegrationData($methodCode);
$configData['methodCode'] = $methodCode;
?>

<div x-data="hyvaCheckoutWhitelabelPaymentMethod"
     data-config="<?= $escaper->escapeHtmlAttr(json_encode($configData)) ?>"
     class="wallee-payment-method-container mt-4"
     id="wallee-container-<?= $escaper->escapeHtmlAttr($methodCode) ?>">
    
    <div
        x-show="isIframeMode"
        id="wallee-iframe-<?= $escaper->escapeHtmlAttr($methodCode) ?>"
        class="wallee-iframe-wrapper border rounded p-2 bg-white shadow-sm" style="display: none;"
        >
        <!-- Iframe will be mounted here -->
    </div>
</div>
